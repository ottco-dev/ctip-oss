# ──────────────────────────────────────────────────────────────────────────────
# docker/dev/Dockerfile.dev
#
# Full development image: CUDA 12.8 + PyTorch (cu128) + all project deps + dev tools.
# Includes hot-reload, Jupyter, profilers, and test runners.
#
# PyTorch wheels: cu128 (CUDA 12.8) from download.pytorch.org/whl/cu128
# flash-attn: optional — installed if a prebuilt wheel exists, skipped otherwise.
# SAM2: installed from Meta's GitHub (not on PyPI).
#
# Build:
#   docker build -f docker/dev/Dockerfile.dev -t trichome-dev .
#
# Run:
#   docker run --gpus all -p 8000:8000 -p 3000:3000 \
#     -v $(pwd):/workspace trichome-dev
# ──────────────────────────────────────────────────────────────────────────────

FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

ARG PYTHON_VERSION=3.12
ARG DEBIAN_FRONTEND=noninteractive

# ── System dependencies ───────────────────────────────────────────
# python3.12 is not in Ubuntu 22.04 default repos — add deadsnakes PPA first
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    gnupg \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    curl \
    ffmpeg \
    git \
    git-lfs \
    htop \
    libglib2.0-0 \
    libgl1-mesa-glx \
    libgomp1 \
    libopencv-dev \
    libsm6 \
    libxext6 \
    libxrender-dev \
    ninja-build \
    nodejs \
    npm \
    python${PYTHON_VERSION} \
    python${PYTHON_VERSION}-dev \
    python${PYTHON_VERSION}-venv \
    vim \
    wget \
    && rm -rf /var/lib/apt/lists/*

# ── Python + uv ───────────────────────────────────────────────────
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:/root/.cargo/bin:$PATH"

RUN ln -s /usr/bin/python${PYTHON_VERSION} /usr/local/bin/python3 \
    && ln -s /usr/local/bin/python3 /usr/local/bin/python

# ── Workspace ─────────────────────────────────────────────────────
WORKDIR /workspace

# ── PyTorch (CUDA 12.8 wheels) — must be first ───────────────────
# Pre-install with the cu128 index so uv never pulls cu130+ wheels
# which would mismatch the CUDA 12.8 toolkit used for extension compilation.
RUN uv pip install --system \
    --index-url https://download.pytorch.org/whl/cu128 \
    "torch>=2.3.0" "torchvision>=0.18.0" "torchaudio>=2.3.0"

# ── Dependency caching layer ──────────────────────────────────────
# hatchling requires LICENSE + README.md alongside pyproject.toml.
# create_pkg_stubs.py creates empty __init__.py stubs for all packages listed
# under [tool.hatch.build.targets.wheel.packages] so hatchling can build a
# valid wheel at this stage. COPY . . below overwrites them with real source.
COPY pyproject.toml LICENSE README.md ./
COPY docker/dev/create_pkg_stubs.py ./create_pkg_stubs.py
RUN python3 create_pkg_stubs.py \
    && uv pip install --system ".[all,dev]" \
    && rm create_pkg_stubs.py

# ── Non-PyPI / CUDA-compiled extras ──────────────────────────────
# SAM2 (segment-anything-2) — Meta GitHub, not on PyPI
RUN uv pip install --system \
    git+https://github.com/facebookresearch/segment-anything-2.git

# flash-attn — optional kernel optimisation for VLM attention layers.
# Requires matching CUDA toolkit + prebuilt wheel for this cu/torch combo.
# Soft-fail: models use standard attention if flash-attn is unavailable.
RUN uv pip install --system flash-attn --no-build-isolation \
    || echo "WARNING: flash-attn not available for this CUDA/torch combination (optional, skipping)"

# ── Dev tools (not in pyproject.toml) ───────────────────────────
RUN uv pip install --system \
    ipython \
    jupyter \
    jupyterlab \
    pytest-xdist \
    pytest-watch \
    memory-profiler \
    line-profiler \
    scalene \
    viztracer

# ── Project source ────────────────────────────────────────────────
COPY . .

# ── CLI entry point (editable install over real source tree) ──────
RUN uv pip install --system -e ".[all,dev]"

# ── Environment ───────────────────────────────────────────────────
ENV PYTHONPATH=/workspace
ENV CUDA_VISIBLE_DEVICES=0
ENV TRICHOME_ENV=development

# ── Ports ─────────────────────────────────────────────────────────
EXPOSE 8000 3000 8888

# ── Default: backend with hot-reload ─────────────────────────────
CMD ["uvicorn", "backend.main:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--reload", \
     "--reload-dir", "/workspace"]
