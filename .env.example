# =============================================================================
# Trichome Analysis System — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
#
# Port layout (host:container mapping):
#   3001 → nginx reverse proxy  (PUBLIC entry: http://ottco.ddns.net:3001)
#   3002 → FastAPI backend      (container: 8000)
#   3003 → Next.js frontend     (container: 3000)
#   3004 → MLflow               (container: 5000)
#   3005 → Label Studio         (container: 8080)
#   3006 → CVAT                 (container: 8080)
#   3007 → PostgreSQL (annot.)  (container: 5432 — NOT exposed publicly)
#
# DDNS: ottco.ddns.net → your public IP → router NAT → port 3001 on this host
# =============================================================================

# --- Project Paths ---
TRICHOME_ROOT=/home/ottcouture/trichome-analysis
DATA_ROOT=/mnt/data/trichome
MODELS_ROOT=/mnt/models/trichome
EXPERIMENTS_ROOT=/mnt/experiments/trichome

# --- CUDA / Hardware ---
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
CUDA_LAUNCH_BLOCKING=0
# GPU rate limiting: max requests queued before HTTP 429 (0 = fail-fast, no queue)
GPU_INFERENCE_QUEUE_DEPTH=0

# --- Model Registry ---
MODEL_REGISTRY_PATH=/mnt/models/trichome/registry
YOLO_WEIGHTS_PATH=/mnt/models/trichome/weights/yolo
SAM2_WEIGHTS_PATH=/mnt/models/trichome/weights/sam2
GROUNDING_DINO_WEIGHTS_PATH=/mnt/models/trichome/weights/groundingdino

# --- VLM Models ---
FLORENCE2_MODEL_ID=microsoft/Florence-2-large
QWEN2VL_MODEL_ID=Qwen/Qwen2-VL-7B-Instruct
MINICPM_MODEL_ID=openbmb/MiniCPM-V-2_6
MOONDREAM_MODEL_ID=vikhyatk/moondream2
VLM_CACHE_DIR=/mnt/models/vlm_cache

# --- Experiment Tracking ---
# Internal URI (within docker network):  http://mlflow:5000
# Host access:                           http://localhost:3004
# Public access (via nginx):             http://ottco.ddns.net:3001/mlflow/
MLFLOW_TRACKING_URI=http://localhost:3004
MLFLOW_EXPERIMENT_NAME=trichome_detection_v1
WANDB_PROJECT=trichome-analysis
WANDB_ENTITY=your_wandb_entity
WANDB_API_KEY=your_wandb_api_key_here
# Set to "mlflow" or "wandb" or "both" or "none"
EXPERIMENT_TRACKER=mlflow

# --- Dataset Management ---
DVC_REMOTE=s3://your-bucket/trichome-dvc
DVC_REMOTE_ACCESS_KEY_ID=your_access_key
DVC_REMOTE_SECRET_ACCESS_KEY=your_secret_key
FIFTYONE_DATABASE_URI=mongodb://localhost:27017
FIFTYONE_DEFAULT_DATASET_NAME=trichome_main

# --- Annotation Services ---
# CVAT: direct host access = http://localhost:3006
#       public via nginx    = http://ottco.ddns.net:3001/cvat/
CVAT_URL=http://localhost:3006
CVAT_USERNAME=admin
CVAT_PASSWORD=your_cvat_password

# Label Studio: direct host access = http://localhost:3005
#               public via nginx    = http://ottco.ddns.net:3001/annotation/
LABEL_STUDIO_URL=http://localhost:3005
LABEL_STUDIO_API_KEY=your_label_studio_api_key

# Label Studio PostgreSQL (internal, not exposed via DDNS)
POSTGRES_USER=labelstudio
POSTGRES_PASSWORD=labelstudio_dev_only_CHANGE_ME
POSTGRES_DB=labelstudio
LABEL_STUDIO_SECRET_KEY=INSECURE_DEV_KEY_CHANGE_IN_PRODUCTION
LABEL_STUDIO_DISABLE_SIGNUP_WITHOUT_LINK=false

# --- API Configuration ---
# FastAPI backend — binds inside container to :8000, exposed on host as :3002
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info
API_RELOAD=false

# --- Security ---
# Single-user API token authentication.
# Leave empty (default) to disable auth in development mode.
# Generate a strong token for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Once set, all API requests must include one of:
#   Authorization: Bearer <token>
#   X-API-Key: <token>
#   ?api_key=<token>
#
# Excluded paths (no auth): /health, /docs, /redoc, /openapi.json, /ws/*
API_TOKEN=
# SECRET_KEY is used for session tokens (future JWT). Change for production.
SECRET_KEY=dev-secret-key-change-in-production-use-secrets.token_urlsafe-32

# CORS — allow frontend and nginx entry point
CORS_ORIGINS=["http://ottco.ddns.net:3001","http://ottco.ddns.net","http://localhost:3001","http://localhost:3003","http://127.0.0.1:3003"]

# --- Frontend ---
# Next.js: all API calls go through nginx when accessed via DDNS
NEXT_PUBLIC_API_URL=http://ottco.ddns.net:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://ottco.ddns.net:3001/ws
# Fallback for direct local access (bypassing nginx)
NEXT_PUBLIC_API_URL_LOCAL=http://localhost:3002/api/v1

# --- Storage ---
RESULTS_STORAGE_PATH=/mnt/data/trichome/results
ANNOTATION_STORAGE_PATH=/mnt/data/trichome/annotations
REPORTS_OUTPUT_PATH=/mnt/data/trichome/reports
CACHE_PATH=/tmp/trichome_cache

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/trichome/system.log
LOG_ROTATION=100MB
LOG_RETENTION=30days

# --- Performance ---
NUM_WORKERS=8
BATCH_SIZE_INFERENCE=4
PREFETCH_FACTOR=2
PIN_MEMORY=true

# --- Scientific Parameters (defaults, override per experiment) ---
DEFAULT_CONFIDENCE_THRESHOLD=0.35
DEFAULT_IOU_THRESHOLD=0.45
DEFAULT_NMS_THRESHOLD=0.50
DEFAULT_TILE_SIZE=1280
DEFAULT_TILE_OVERLAP=0.2
UNCERTAINTY_SAMPLES=20

# --- Reproducibility ---
GLOBAL_SEED=42

# --- HuggingFace ---
HF_TOKEN=your_huggingface_token_here
HF_HOME=/mnt/models/hf_cache
